# Keep the build context small and secret-free.
# CRITICAL: without this, `COPY . .` copies the HOST node_modules into the image,
# shadowing the Linux `npm ci` install with (possibly Windows-built) native modules.
node_modules
npm-debug.log*
yarn-error.log*

.git
.gitignore
.github

.env
.env.*
!.env.example

dist
build
out
.next
coverage
.nyc_output

tests
__tests__
*.test.js
*.spec.js

*.md
!README.md
.DS_Store
Thumbs.db