# ===========================================================
# 🚀 Nifty 50 Trading System - Environment Variables
# ===========================================================
#
# SETUP:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your API credentials via Dashboard → Broker Providers
#   3. Run: make up
#
# ⚠️  NEVER commit your .env file to git!
#
# ===========================================================

# ===========================================================
# 🌐 PROVIDER SELECTION (Fallback only — primary is Dashboard)
# ===========================================================
# No broker credentials here. Manage them via Dashboard → Broker Providers.
# L1/L10 auto-discover enabled providers from the L7 API at startup.
# This env var is only used if the L7 API is unreachable.
SKIP_HISTORICAL_SYNC=false
MARKET_DATA_PROVIDER=mstock

# ===========================================================
# 🗄️ INFRASTRUCTURE (Defaults work for local Docker)
# ===========================================================
# ⚠️  SECURITY WARNING: Change ALL passwords before production!
# These are EXAMPLE values - NEVER use in production
# ===========================================================

# --- Database ---
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_THIS_IN_PRODUCTION_trading123
POSTGRES_DB=nifty50

# PgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_MASTER_KEY=
REDIS_HOST=redis
KAFKA_BROKERS=kafka:29092

# =========================================================
# INGESTION SETTINGS
# =========================================================
# Number of parallel workers for Swarm data fetching
# Higher = faster data pull, but more API load
# Default: 12, Recommended for speed: 20
SWARM_CONCURRENCY=20

# Force historical mode (disable live streaming even when market is open)
# Set to true during development/backfill, false for production live trading
FORCE_HISTORICAL_MODE=false

# =========================================================
# MOMENTUM MODULE SETTINGS (Phase A+)
# =========================================================

# Option Chain Poller (uses FlatTrade API if configured)
# OPTION_CHAIN_POLL_INTERVAL_MS=3000
# OPTION_UNDERLYING=NIFTY
# KAFKA_TOPIC_OPTION_CHAIN=option-chain

# =========================================================
# REGIME ENGINE SETTINGS (Phase B)
# =========================================================
# REGIME_POLL_INTERVAL_MS=60000
# REGIME_SYMBOL=NIFTY
# KAFKA_TOPIC_MARKET_REGIME=market-regime

# =========================================================
# EXECUTION ENGINE SETTINGS (Phase E)
# =========================================================
# TRADE_MODE=paper        # paper | shadow | live
# EXECUTION_BROKER=flattrade   # flattrade | mstock
# UNDERLYING=NIFTY
# MAX_LOTS=1
# MAX_CONCURRENT_POSITIONS=1
# MAX_TRADES_PER_DAY=5
# MAX_DAILY_LOSS=2500
# STOP_LOSS_PCT=18
# TARGET_PCT=25

# =========================================================
# VALIDATION SETTINGS (Phase F)
# =========================================================
# SEBI_REGISTERED=false       # Set to true after SEBI algo registration
# BROKER_RATE_LIMITS_CONFIRMED=false
