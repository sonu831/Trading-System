{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/Badge/**",
              "components/core/Button/**",
              "components/core/Card/**",
              "components/core/Input/**",
              "components/data/RiskMeter/**",
              "components/data/StatTile/**",
              "components/data/Table/**",
              "components/feedback/KillSwitchButton/**",
              "components/feedback/StaleBadge/**",
              "components/feedback/TradeModeBadge/**",
              "components/overlay/Modal/**",
              "components/trading/DailyRiskCard/**",
              "components/trading/OptionChainGrid/**",
              "components/trading/PositionsTable/**",
              "components/trading/SafetyBar/**",
              "ui_kits/trading-cockpit/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|loading|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, loading, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|hoverable|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, hoverable, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DailyRiskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:dailyLoss|maxDailyLoss|tradesToday|maxTrades|halted|className|key|ref|className|style|children)$/]",
        "message": "<DailyRiskCard> doesn't accept that prop. Declared props: dailyLoss, maxDailyLoss, tradesToday, maxTrades, halted, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|helperText|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, helperText."
      },
      {
        "selector": "JSXOpeningElement[name.name='KillSwitchButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onToggle|className|key|ref|className|style|children)$/]",
        "message": "<KillSwitchButton> doesn't accept that prop. Declared props: active, onToggle, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:isOpen|onClose|size|children|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: isOpen, onClose, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Modal> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionChainRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:strike|ce|pe|key|ref|className|style|children)$/]",
        "message": "<OptionChainRow> doesn't accept that prop. Declared props: strike, ce, pe."
      },
      {
        "selector": "JSXOpeningElement[name.name='Position'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|symbol|optionType|lots|currentPrice|stopLoss|pnl|key|ref|className|style|children)$/]",
        "message": "<Position> doesn't accept that prop. Declared props: id, symbol, optionType, lots, currentPrice, stopLoss, pnl."
      },
      {
        "selector": "JSXOpeningElement[name.name='Position'] > JSXAttribute[name.name='optionType'] > Literal[value!=/^(?:CE|PE)$/]",
        "message": "<Position> optionType must be one of 'CE' | 'PE'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|used|limit|formatValue|invertWords|className|key|ref|className|style|children)$/]",
        "message": "<RiskMeter> doesn't accept that prop. Declared props: label, used, limit, formatValue, invertWords, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SafetyBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:underlying|spot|tradeModeBadge|staleBadge|killSwitchButton|className|key|ref|className|style|children)$/]",
        "message": "<SafetyBar> doesn't accept that prop. Declared props: underlying, spot, tradeModeBadge, staleBadge, killSwitchButton, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StaleBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:timestamp|warnAfter|staleAfter|label|className|key|ref|className|style|children)$/]",
        "message": "<StaleBadge> doesn't accept that prop. Declared props: timestamp, warnAfter, staleAfter, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|delta|deltaLabel|deltaTone|icon|footnote|className|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, tone, delta, deltaLabel, deltaTone, icon, footnote, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|positive|negative|warning)$/]",
        "message": "<StatTile> tone must be one of 'neutral' | 'positive' | 'negative' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:neutral|positive|negative|warning)$/]",
        "message": "<StatTile> deltaTone must be one of 'neutral' | 'positive' | 'negative' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Table'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|key|ref|className|style|children)$/]",
        "message": "<Table> doesn't accept that prop. Declared props: children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TradeModeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|className|key|ref|className|style|children)$/]",
        "message": "<TradeModeBadge> doesn't accept that prop. Declared props: mode, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TradeModeBadge'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:paper|shadow|live)$/]",
        "message": "<TradeModeBadge> mode must be one of 'paper' | 'shadow' | 'live'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
