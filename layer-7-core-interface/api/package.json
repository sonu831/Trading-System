{
  "name": "layer-7-api",
  "version": "0.2.4",
  "description": "REST API for Nifty 50 Trading System",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "pnpm run verify",
    "verify": "pnpm run verify:api-auth && pnpm run verify:broker-auth && pnpm run verify:execution-proxy",
    "verify:api-auth": "node --import tsx tests/verify-api-auth.js",
    "verify:broker-auth": "node --import tsx tests/verify-broker-auth.js",
    "verify:execution-proxy": "node --import tsx tests/verify-execution-proxy.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@mstock-mirae-asset/nodetradingapi-typeb": "^0.0.3",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "awilix": "^13.0.5",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-awilix": "^1.3.0",
    "fastify-caching": "^6.3.0",
    "fastify-plugin": "^6.0.0",
    "fastify-socket.io": "^5.1.0",
    "otpauth": "^9.5.1",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "pg-cursor": "^2.21.0",
    "pino-loki": "^3.0.0",
    "piscina": "^5.2.0",
    "prom-client": "^15.1.3",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3"
  }
}
