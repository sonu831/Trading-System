{
  "name": "layer-7-api",
  "version": "0.2.4",
  "description": "REST API for Nifty 50 Trading System",
  "main": "src/index.ts",
  "scripts": {
    "start": "pm2-runtime ecosystem.config.js",
    "dev": "tsx watch src/index.ts",
    "test": "pnpm run verify",
    "verify": "pnpm run verify:broker-auth && pnpm run verify:execution-proxy",
    "verify:broker-auth": "node -r ts-node/register tests/verify-broker-auth.js",
    "verify:execution-proxy": "node -r ts-node/register tests/verify-execution-proxy.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@mstock-mirae-asset/nodetradingapi-typeb": "^0.0.2",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "awilix": "^12.0.5",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.2.0",
    "fastify-awilix": "^1.3.0",
    "fastify-caching": "^6.3.0",
    "fastify-plugin": "^5.0.1",
    "fastify-socket.io": "^5.1.0",
    "otpauth": "^9.4.1",
    "pg": "^8.11.3",
    "pg-cursor": "^2.17.0",
    "p-limit": "^3.1.0",
    "pino-loki": "^3.0.0",
    "piscina": "^5.1.4",
    "prom-client": "^14.2.0",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "typescript": "^5.6.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^6.19.2"
  }
}
